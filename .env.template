# ════════════════════════════════════════════════════════════════
#  EGX Trading System — Environment Variables Template
#  نسخ هذا الملف إلى .env وتعبئة القيم المطلوبة
#  Copy this file to .env and fill in the required values
# ════════════════════════════════════════════════════════════════

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# أنشئ بوت من @BotFather على Telegram واحصل على TOKEN
# Create a bot via @BotFather on Telegram and get the TOKEN
TELEGRAM_BOT_TOKEN=

# معرّف القناة أو الشخص — يبدأ بـ - للقنوات
# Chat ID of user or channel — use @userinfobot to get yours
TELEGRAM_CHAT_ID=

# ── Email (اختياري / Optional) ───────────────────────────────────────────────
# يمكن استخدام SendGrid أو Resend أو SMTP2Go
# Use SendGrid, Resend, or any email API
EMAIL_API_KEY=
EMAIL_FROM=egx-system@yourdomain.com
EMAIL_TO=

# ── Python Bridge ─────────────────────────────────────────────────────────────
# مسار Python — اتركه فارغاً لاستخدام python3
# Python binary path — leave empty to use python3
PYTHON_BIN=python3

# مهلة Python بالمللي ثانية (120 ثانية افتراضي)
PY_TIMEOUT=120000

# ── Database ──────────────────────────────────────────────────────────────────
# مسار قاعدة البيانات (افتراضي: data/egx.db)
DB_PATH=

# ── Macro Data APIs ───────────────────────────────────────────────────────────
# مجانية ولا تحتاج مفتاح — يمكن تجاوزها
# Free APIs — no key required, can be left empty

# ExchangeRate-API key (اختياري — الطبقة المجانية تعمل بدون مفتاح)
EXCHANGE_RATE_API_KEY=

# ── TradingView MCP / CDP ─────────────────────────────────────────────────────
# desktop = TradingView Desktop (open -a --args)
# chrome  = Google Chrome يفتح tradingview.com (موصى به على macOS الحديث)
# auto    = Desktop أولاً ثم Chrome تلقائياً إذا فشل
TV_CDP_BROWSER=chrome
TV_CDP_PORT=9222
TV_CDP_URL=https://www.tradingview.com/chart/?symbol=EGX_DLY:COMI

# ── Automation ────────────────────────────────────────────────────────────────
# وقت التشغيل اليومي التلقائي (HH:MM بتوقيت القاهرة)
# Daily automation time (HH:MM Cairo time) — used by cron scripts
DAILY_RUN_TIME=16:30

# هل ترسل التقرير تلقائياً بعد كل تحديث يومي؟ (true/false)
AUTO_NOTIFY=true

# ── EGX Safety & Portfolio (Jackson bot pattern — no broker) ─────────────────
# فحص TRADING_LESSONS قبل الإرسال — 0 لتعطيل الفيتو
EGX_SAFETY_VETO=1
# أقصى إشارات للعميل يومياً / أقصى مراكز مفتوحة
EGX_MAX_SIGNALS_PER_DAY=3
EGX_MAX_OPEN_POSITIONS=6
# وضع ورقي — يسجل فقط بدون تنفيذ وسيط
EGX_PAPER_TRADING=true
# استيراد الإشارات تلقائياً لـ portfolio_tracker بعد Telegram
EGX_PORTFOLIO_AUTO=1
# إرسال تنبيهات الأعطال لنفس بوت Telegram (0 لتعطيل)
EGX_ALERT_TELEGRAM=1
# تنبيه نجاح التسليم/post-session (0 = فشل فقط)
EGX_OPS_SUCCESS_ALERT=1
# استعادة تلقائية للإرسالات المعلقة في post-session (0 = يدوي فقط)
EGX_AUTO_BACKFILL=0

# ── Crypto scalper (اختياري — BitGet فقط، منفصل عن EGX) ─────────────────────
